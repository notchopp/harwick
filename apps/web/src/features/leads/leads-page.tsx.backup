type LeadSource = "instagram" | "facebook" | "voice";
type LeadStage = "hot" | "qualified" | "unrouted" | "callback" | "nurture" | "showing";
type LeadFilter = "all" | LeadStage | "seller";
type LeadCardKind = "listing" | "area" | "seller";
type LeadViewMode = "grid" | "list";
type AreaTheme = "waterfront" | "suburban" | "unknown";
type RolePreview = "owner" | "admin" | "team_lead" | "agent";

type LeadRecord = {
  areaTheme?: AreaTheme;
  automationMode: ConversationAutomationMode;
  automationReason: string;
  helperSuggestions: string[];
  primaryAction: string;
  secondaryAction: string;
  cardKind: LeadCardKind;
  id: string;
  name: string;
  initials: string;
  source: LeadSource;
  sourceDetail: string;
  stage: LeadStage;
  stageLabel: string;
  imageUrl: string;
  intent: string;
  signal: string;
  score: number;
  budget: string;
  area: string;
  timeline: string;
  propertyType: string;
  assignedTo: string;
  sourceOwner: string;
  lastTouch: string;
  nextAction: string;
  routeReason: string;
  listing: string;
  message: string;
  draft: string;
  sellerEstimate?: string;
  sellerProperty?: {
    address: string;
    city: string;
  };
  sellerTarget?: string;
  timelineItems: string[];
};

type ActivityItem = {
  detail: string;
  label: string;
  time: string;
  tone: "green" | "amber" | "stone";
};

