# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Customer-zero seed data
REALTY_OPS_WORKSPACE_NAME=
REALTY_OPS_WORKSPACE_SLUG=
REALTY_OPS_OWNER_USER_ID=
REALTY_OPS_OWNER_EMAIL=
REALTY_OPS_OWNER_DISPLAY_NAME=
REALTY_OPS_META_PROVIDER_ACCOUNT_ID=
REALTY_OPS_META_PROVIDER_ACCOUNT_NAME=

# Meta / Instagram
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/meta/oauth/callback
CREDENTIAL_ENCRYPTION_KEY=change-me-to-a-long-random-secret
META_PAGE_ID=
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=

# Retell
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=
RETELL_AGENT_ID=
# Optional: clone an existing Retell flow before applying the Realty Ops voice graph.
RETELL_CONVERSATION_FLOW_TEMPLATE_ID=
RETELL_VOICE_ID=

# Follow Up Boss
FOLLOWUPBOSS_API_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SOLO_MONTHLY_PRICE_ID=
STRIPE_SOLO_YEARLY_PRICE_ID=
STRIPE_TEAM_MONTHLY_PRICE_ID=
STRIPE_TEAM_YEARLY_PRICE_ID=
STRIPE_BROKERAGE_MONTHLY_PRICE_ID=
STRIPE_BROKERAGE_YEARLY_PRICE_ID=

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google-calendar/callback

# Listing providers
# Leave LISTING_PROVIDER unset to stay cache/manual-only. Set to repliers to enable live listing lookup.
LISTING_PROVIDER=
REPLIERS_API_KEY=
REPLIERS_BOARD_ID=

# Follow Up Boss webhooks
# These are per-workspace subscriptions stored in Supabase; each workspace registration generates its own callback token and signing secret.

# Worker
WORKER_ID=realty-ops-worker-local
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=10

# AI
OPENAI_API_KEY=
OPENAI_REPLY_MODEL=gpt-5.2
ANTHROPIC_API_KEY=

# Agent runtime cron
# AGENT_RECONCILE_CRON_SECRET protects manual/external calls to the reconcile and embedding routes.
# CRON_SECRET is set by Vercel Cron when scheduled jobs call those routes.
AGENT_RECONCILE_CRON_SECRET=
CRON_SECRET=

# Launch smoke checks
# Set LAUNCH_PROVIDER_SMOKE_BASE_URL to a deployed staging app URL to exercise public readiness,
# Meta webhook challenge, and Retell signed webhook paths. Set REQUIRED to true in pre-launch CI.
LAUNCH_PROVIDER_SMOKE_BASE_URL=
LAUNCH_PROVIDER_SMOKE_BYPASS_SECRET=
LAUNCH_PROVIDER_SMOKE_REQUIRED=false
LAUNCH_ENV_AUDIT_REQUIRED=false

# Mapbox public token (pk.*) for the onboarding primary-areas map. Browser-safe.
# Get one from https://account.mapbox.com/access-tokens/ — free tier covers all expected onboarding traffic.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
