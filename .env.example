# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Customer-zero seed data
REALTY_OPS_WORKSPACE_NAME=
REALTY_OPS_WORKSPACE_SLUG=
REALTY_OPS_OWNER_USER_ID=
REALTY_OPS_OWNER_EMAIL=
REALTY_OPS_OWNER_DISPLAY_NAME=
REALTY_OPS_META_PROVIDER_ACCOUNT_ID=
REALTY_OPS_META_PROVIDER_ACCOUNT_NAME=

# Meta / Instagram
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/meta/oauth/callback
CREDENTIAL_ENCRYPTION_KEY=change-me-to-a-long-random-secret
META_PAGE_ID=
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=

# Retell
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=
RETELL_AGENT_ID=
RETELL_CONVERSATION_FLOW_TEMPLATE_ID=
RETELL_VOICE_ID=

# Follow Up Boss
FOLLOWUPBOSS_API_KEY=

# Listing providers
# Leave LISTING_PROVIDER unset to stay cache/manual-only. Set to repliers to enable live listing lookup.
LISTING_PROVIDER=
REPLIERS_API_KEY=
REPLIERS_BOARD_ID=

# Follow Up Boss webhooks
# These are per-workspace subscriptions stored in Supabase; each workspace registration generates its own callback token and signing secret.

# Worker
WORKER_ID=realty-ops-worker-local
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=10

# AI
OPENAI_API_KEY=
OPENAI_REPLY_MODEL=gpt-5.2
ANTHROPIC_API_KEY=
