APP_ENV=staging
NEXT_PUBLIC_APP_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

REALTY_OPS_WORKSPACE_NAME=
REALTY_OPS_WORKSPACE_SLUG=
REALTY_OPS_OWNER_USER_ID=
REALTY_OPS_OWNER_EMAIL=
REALTY_OPS_OWNER_DISPLAY_NAME=
REALTY_OPS_META_PROVIDER_ACCOUNT_ID=
REALTY_OPS_META_PROVIDER_ACCOUNT_NAME=

META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_OAUTH_REDIRECT_URI=
CREDENTIAL_ENCRYPTION_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=
# Optional: clone an existing Retell flow before applying the Realty Ops voice graph.
RETELL_CONVERSATION_FLOW_TEMPLATE_ID=
RETELL_VOICE_ID=
FOLLOWUPBOSS_API_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SOLO_MONTHLY_PRICE_ID=
STRIPE_SOLO_YEARLY_PRICE_ID=
STRIPE_TEAM_MONTHLY_PRICE_ID=
STRIPE_TEAM_YEARLY_PRICE_ID=
STRIPE_BROKERAGE_MONTHLY_PRICE_ID=
STRIPE_BROKERAGE_YEARLY_PRICE_ID=

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_OAUTH_REDIRECT_URI=

# Listing providers
# Leave LISTING_PROVIDER unset to stay cache/manual-only. Set to repliers to enable live listing lookup.
LISTING_PROVIDER=
REPLIERS_API_KEY=
REPLIERS_BOARD_ID=

# Follow Up Boss webhooks
# These are per-workspace subscriptions stored in Supabase; each workspace registration generates its own callback token and signing secret.

OPENAI_API_KEY=
OPENAI_REPLY_MODEL=gpt-5.2

AGENT_RECONCILE_CRON_SECRET=
CRON_SECRET=

WORKER_ID=realty-ops-worker-staging
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=10

LAUNCH_PROVIDER_SMOKE_BASE_URL=
LAUNCH_PROVIDER_SMOKE_BYPASS_SECRET=
LAUNCH_PROVIDER_SMOKE_REQUIRED=true
LAUNCH_ENV_AUDIT_REQUIRED=true
