{
  "buildCommand": "npm run typecheck && npm run build",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/agent-runtime/reconcile",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/agent-runtime/embed",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/agent-runtime/insights",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/agent-runtime/workspace-memory",
      "schedule": "0 */6 * * *"
    }
  ]
}
