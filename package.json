{
  "name": "harwick",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "constraints:check": "node scripts/validate-codex-constraints.mjs",
    "dev": "npm run dev --workspace @realty-ops/web",
    "worker:dev": "npm run dev --workspace @realty-ops/worker",
    "worker:start": "npm run start --workspace @realty-ops/worker",
    "build:packages": "tsc --build packages/core packages/integrations packages/api-client --pretty false --force",
    "lint": "eslint .",
    "test": "vitest run",
    "test:launch-funnel": "vitest run tests/launch/full-funnel.test.ts",
    "test:launch-readiness": "vitest run tests/launch/full-funnel.test.ts tests/launch/runtime-readiness.test.ts",
    "test:staging-provider-smoke": "vitest run tests/launch/staging-provider-smoke.test.ts",
    "launch:env:audit": "node scripts/audit-vercel-env.mjs",
    "launch:env:sources": "node scripts/audit-local-launch-env-sources.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --build --pretty false",
    "build": "npm run build:packages && npm run build --workspace @realty-ops/web",
    "supabase:migrate": "node scripts/apply-supabase-migration.mjs",
    "supabase:seed": "node scripts/seed-customer-zero.mjs",
    "supabase:test:rls": "node scripts/test-rls.mjs",
    "launch:check": "node scripts/launch-check.mjs",
    "release:check": "npm run constraints:check && npm run typecheck && npm run lint && npm test"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "date-fns": "^4.1.0",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "retell-sdk": "^5.16.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^20.17.30",
    "eslint": "^9.25.1",
    "shadcn": "^4.6.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20.19.4"
  }
}
